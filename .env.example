# =============================================================================
# Hot Pulse 环境变量模板
# =============================================================================
# 使用方法：复制此文件为 .env 并填入真实值
#   cp .env.example .env
#
# 说明：
#   - [必需] = 不填则程序无法启动
#   - [可选] = 可在 config.yaml 中配置同名项来替代，或留空使用默认值
# =============================================================================

# ---------------------------------------------------------------------------
# TikHub API — 抖音/微信视频号数据获取
# ---------------------------------------------------------------------------
# 获取方式：https://api.tikhub.io 注册后获取
TIKHUB_API_KEY=tk_your_api_key_here

# ---------------------------------------------------------------------------
# 飞书应用 — 多维表格读写认证
# ---------------------------------------------------------------------------
# 获取方式：飞书开放平台 → 创建应用 → 凭证与基础信息
FEISHU_APP_ID=cli_your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# ---------------------------------------------------------------------------
# 飞书多维表格 — 表格标识
# ---------------------------------------------------------------------------
# [可选] 也可以在 config.yaml 的 feishu.bitable 中直接配置
# app_token: 从多维表格 URL 中获取（https://xxx.feishu.cn/base/{app_token}?...）
# table_id:  从数据表 URL 参数中获取（?table={table_id}）
FEISHU_BITABLE_APP_TOKEN=your_feishu_bitable_app_token_here
FEISHU_BITABLE_TABLE_ID=your_feishu_bitable_table_id_here

# ---------------------------------------------------------------------------
# 钉钉自定义机器人 — 分析报告推送
# ---------------------------------------------------------------------------
# [可选] webhook_url 也可以在 config.yaml 的 dingtalk_worker.webhook_url 中配置
# 获取方式：钉钉群 → 群设置 → 机器人 → 自定义机器人 → Webhook 地址
#          安全设置中选择"加签"，将密钥填入 DINGTALK_SECRET
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=your_access_token_here
DINGTALK_SECRET=your_dingtalk_secret_here

# ---------------------------------------------------------------------------
# OpenAI 兼容 API — LLM 内容分析
# ---------------------------------------------------------------------------
# 支持的 API 提供商：
#   DeepSeek: https://platform.deepseek.com/api_keys
#   智谱:     https://open.bigmodel.cn/usercenter/apikeys
#   其他兼容 OpenAI 接口的服务均可
# 对应的 base_url 在 config.yaml 的 analyze_worker.openai_base_url 中配置
OPENAI_API_KEY=your_openai_api_key_here

# ---------------------------------------------------------------------------
# HuggingFace 镜像 — 模型下载加速（可选）
# ---------------------------------------------------------------------------
# [可选] 国内环境建议设置，用于加速 Whisper 模型下载
# 默认值：https://hf-mirror.com
# HF_ENDPOINT=https://hf-mirror.com
