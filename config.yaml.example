# Hot Pulse 配置文件
# 复制此文件为 config.yaml 并填入实际值

tikhub:
  base_url: https://api.tikhub.io
  endpoint: /api/v1/douyin/app/v3/fetch_user_post_videos
  fallback_endpoint: /api/v1/douyin/web/fetch_user_post_videos  # 主接口失败 3 次后降级的备用接口，设为空禁用
  max_count: 10

feishu:
  bitable:
    app_token: your_feishu_bitable_app_token_here    # 从飞书多维表格 URL 中获取，或使用环境变量 FEISHU_BITABLE_APP_TOKEN
    table_id: your_table_id_here       # 从数据表 URL 参数中获取

creators:
  - name: 创作者名称
    sec_uid: your_creator_sec_uid_here  # 替换为实际 sec_uid，或使用环境变量 CREATOR_*_SEC_UID
  # - name: 创作者2
  #   sec_uid: your_creator_sec_uid_here

schedule:
  interval_minutes: 59

zeromq:
  enabled: true
  push_endpoint: "tcp://127.0.0.1:5551"

download_worker:
  pull_endpoint: "tcp://127.0.0.1:5551"
  push_endpoint: "tcp://127.0.0.1:5552"
  download_dir: "D:\\batch\\video"
  url_priority:
    "*.amemv.com": 10
    "v26-web.douyinvod.com": 5
    "v3-search.douyinvod.com": 0

extract_audio_worker:
  pull_endpoint: "tcp://127.0.0.1:5552"
  push_endpoint: "tcp://127.0.0.1:5553"
  audio_dir: "D:\\batch\\audio"

transcribe_worker:
  pull_endpoint: "tcp://127.0.0.1:5553"
  push_endpoint: "tcp://127.0.0.1:5554"
  text_dir: "D:\\batch\\text"
  model_dir: "D:\\batch\\whisper-model"
  model_size: "medium"
  device: "gpu"

analyze_worker:
  pull_endpoint: "tcp://127.0.0.1:5554"
  push_endpoint: "tcp://127.0.0.1:5555"
  report_dir: "D:\\docs\\财经\\02-市场分析\\视频分析报告"
  model: "deepseek-v4-flash"          # LLM 模型 ID，也可改为 deepseek-v4-pro / glm-5.1 等
  # prompt: ""                        # 留空则使用内置默认 prompt（财经分析师）
  openai_base_url: "https://api.deepseek.com/v1"  # OpenAI 兼容 API 基础 URL，不含 /chat/completions
  reasoning_effort: "high"            # 推理深度：high / max，留空则不发送该字段
  extra_body:                         # 厂商专属参数，展开合并到请求体
    # thinking:                        # DeepSeek V4 thinking 模式开关
    #   type: "enabled"                # "enabled"（开启）/ "disabled"（关闭），思考模式下不支持 temperature

dingtalk_worker:
  pull_endpoint: "tcp://127.0.0.1:5555"
  push_endpoint: "tcp://127.0.0.1:5556"
  webhook_url: "your_dingtalk_webhook_url_here"  # 钉钉自定义机器人 Webhook 地址，或使用环境变量 DINGTALK_WEBHOOK_URL
  min_interval: 120

patrol_worker:
  interval_minutes: 60
  zombie_threshold_minutes: 90
